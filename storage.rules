rules_version = '2';

// Firebase Storage rules for DepositTrack photos & signatures.
// Photos are namespaced under inspections/{inspectionId}/...
// Tighten further (per-collaborator checks) once Firestore membership is wired.
service firebase.storage {
  match /b/{bucket}/o {
    match /inspections/{inspectionId}/{allPaths=**} {
      // Any authenticated user may read; only authenticated users may write,
      // and uploads are capped at 15 MB and must be images.
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
