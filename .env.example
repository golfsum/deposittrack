# DepositTrack environment variables.
# Copy to ".env" and fill in. Anything prefixed EXPO_PUBLIC_ is bundled into the
# app at build time (these are public client values, not secrets).
#
# PowerShell: copy with  ->  Copy-Item .env.example .env

# --- Firebase Web config (Firebase console -> Project settings -> Your apps) ---
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Google OAuth client IDs (Google Cloud console / Firebase Auth) ---
# Web client ID is required for Firebase signInWithCredential on every platform.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# --- EAS ---
EXPO_PUBLIC_EAS_PROJECT_ID=

# --- Native build only (not bundled into JS) ---
APPLE_TEAM_ID=
